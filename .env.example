# Copy to .env or .env.local and fill in your values.
# See README for setup instructions.

DATABASE_URL="postgresql://YOUR_USER@localhost:5432/resume_app?schema=public"

OPENAI_API_KEY="sk-your-openai-key"

NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-public-anon-key"

# Optional: used for server-side Supabase operations (keep secret)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Supabase db password (if needed)
SUPABASE_PASSWORD="your-password"

# Name of the Supabase storage bucket for resumes
SUPABASE_STORAGE_BUCKET="resume_app"
